{
  "permissions": {
    "allow": [
      "Bash(python -m pytest *)",
      "Bash(python -m ruff check *)",
      "Bash(python -m mypy *)",
      "Bash(python3 -m pytest *)",
      "Bash(python3 -m ruff check *)",
      "Bash(python3 -m mypy *)",
      "Bash(git rev-parse *)"
